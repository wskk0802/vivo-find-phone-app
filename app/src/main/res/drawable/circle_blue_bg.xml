<?xml version="1.0" encoding="utf-8"?>
<!-- 澎湃OS 风格圆形图标背景：蓝紫渐变 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:startColor="#6C7AE0"
                android:centerColor="#5B6ABF"
                android:endColor="#8B95D6" />
            <!-- 内阴影效果 -->
            <stroke
                android:width="1dp"
                android:color="#25FFFFFF" />
        </shape>
    </item>
</layer-list>
