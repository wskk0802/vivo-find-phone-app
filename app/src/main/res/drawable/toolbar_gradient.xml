<?xml version="1.0" encoding="utf-8"?>
<!-- 澎湃OS 风格 Toolbar：蓝紫渐变 + 毛玻璃感 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 主渐变 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#6C7AE0"
                android:centerColor="#5B6ABF"
                android:endColor="#8B95D6" />
        </shape>
    </item>

    <!-- 顶部微光覆盖 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#18FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

</layer-list>
