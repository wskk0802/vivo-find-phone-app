<?xml version="1.0" encoding="utf-8"?>
<!-- 澎湃OS 风格 启动闪屏页
     特征：柔和渐变背景 + 毛玻璃卡片 + 弹性动画 -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash"
    android:fitsSystemWindows="true">

    <!-- 装饰光晕（左上） -->
    <View
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-60dp"
        android:layout_marginTop="-40dp"
        android:background="@drawable/bg_splash"
        android:alpha="0.5" />

    <!-- 装饰光晕（右下） -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-40dp"
        android:layout_marginBottom="-30dp"
        android:background="@drawable/bg_splash"
        android:alpha="0.4" />

    <!-- 中心内容 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- 图标容器（毛玻璃效果） -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp">

            <ImageView
                android:id="@+id/splashIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/hyper_primary)"
                android:contentDescription="App图标" />

        </FrameLayout>

        <!-- 应用名称 -->
        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="亲友位置查找"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/hyper_text_primary"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.03" />

        <!-- 副标题 -->
        <TextView
            android:id="@+id/splashSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="vivo 云服务 · 便捷版"
            android:textSize="14sp"
            android:textColor="@color/hyper_text_tertiary"
            android:letterSpacing="0.05" />

    </LinearLayout>

    <!-- 底部版本号 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="48dp"
        android:text="v1.0.0"
        android:textSize="12sp"
        android:textColor="@color/hyper_text_tertiary"
        android:alpha="0.6" />

</FrameLayout>
