<?xml version="1.0" encoding="utf-8"?>
<!-- 澎湃OS 风格 登录/账号设置界面
     特征：毛玻璃卡片 + 大圆角 + 柔和渐变背景 + 通透感 -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash"
    android:fitsSystemWindows="true"
    tools:context=".ui.login.LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ========== 顶部图标区域 ========== -->
        <FrameLayout
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="20dp">

            <!-- 图标背景光晕 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circle_blue_bg"
                android:alpha="0.15" />

            <!-- 图标 -->
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_search"
                android:contentDescription="定位图标"
                app:tint="#5B6ABF" />

        </FrameLayout>

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="设置 vivo 账号"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/hyper_text_primary"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:text="保存后打开App即可自动填充登录"
            android:textSize="14sp"
            android:textColor="@color/hyper_text_tertiary" />

        <!-- ========== 毛玻璃卡片：输入区域 ========== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#CCFFFFFF"
            app:strokeWidth="1dp"
            app:strokeColor="#33FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- 账号输入 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="vivo 账号（手机号/邮箱）"
                    style="@style/HyperTextInput">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAccount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1"
                        android:imeOptions="actionNext"
                        android:textColor="@color/hyper_text_primary"
                        android:textSize="16sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- 密码输入 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:hint="密码"
                    style="@style/HyperTextInput">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:imeOptions="actionDone"
                        android:textColor="@color/hyper_text_primary"
                        android:textSize="16sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- 记住密码 -->
                <CheckBox
                    android:id="@+id/cbRemember"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="记住密码（加密保存在本机）"
                    android:textColor="@color/hyper_text_secondary"
                    android:textSize="14sp"
                    android:checked="true"
                    android:buttonTint="@color/hyper_primary" />

                <!-- 显示密码 -->
                <CheckBox
                    android:id="@+id/cbShowPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="显示密码"
                    android:textColor="@color/hyper_text_secondary"
                    android:textSize="14sp"
                    android:buttonTint="@color/hyper_primary" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========== 安全提示 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="3dp"
                android:layout_height="14dp"
                android:background="@color/hyper_primary"
                android:alpha="0.6" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="账号密码仅本机加密存储，不上传任何服务器"
                android:textSize="12sp"
                android:textColor="@color/hyper_text_tertiary" />

        </LinearLayout>

        <!-- ========== 按钮组 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="清除"
                android:textColor="@color/hyper_primary"
                app:strokeColor="@color/hyper_primary"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:layout_marginStart="8dp"
                android:text="保存并启用"
                app:backgroundTint="@null"
                android:background="@drawable/bg_hyper_button"
                app:cornerRadius="16dp" />

        </LinearLayout>

        <!-- ========== 使用说明卡片 ========== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#E8F0FE"
            app:strokeWidth="0.5dp"
            app:strokeColor="#338B95D6">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 使用说明"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/hyper_text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="1. 输入你的 vivo 账号密码并保存\n2. 打开App自动填充并登录\n3. 直接进入查找设备页面查看亲友位置\n4. 可在设置中开启指纹验证保护隐私"
                    android:textSize="13sp"
                    android:textColor="@color/hyper_text_secondary"
                    android:lineSpacingExtra="6dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
